# Cache-Control headers for static asset types.
# These take effect on Netlify and Cloudflare Pages.
# GitHub Pages does not honour this file, but it's here for forward-compatibility.

# Immutable versioned Astro build output (hashed filenames — safe to cache forever).
# This covers processed images (/_astro/*.webp), JS, and CSS bundles.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Static public assets (logos, manifest, etc.) — long TTL, bust by changing the file.
/uploads/*
  Cache-Control: public, max-age=31536000, immutable

# Web fonts served locally (if ever self-hosted)
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
/*.woff
  Cache-Control: public, max-age=31536000, immutable

# HTML documents — short TTL so content stays fresh
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# PWA manifest — medium TTL
/site.webmanifest
  Cache-Control: public, max-age=86400
