---
/**
 * Footer.astro
 * ─────────────
 * Dark footer with:
 *  - Brand info, address, Instagram link
 *  - Two nav link groups
 *  - Copyright bar
 *
 * To add a link group: edit footerGroups below.
 */
const footerGroups = [
  {
    title: 'Navigate',
    links: [
      { text: 'Home',    href: '/' },
      { text: 'About',   href: '/about-us' },
      { text: 'News',    href: '/news' },
    ],
  },
  {
    title: 'Connect',
    links: [
      { text: 'Contact',   href: '/contact' },
      { text: 'Sponsor Us', href: '/sponsor' },
    ],
  },
];

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-main">
    <div class="container footer-grid">

      <!-- Brand column -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <div class="footer-logo__icon">
            <img
              src="/uploads/aero logo.svg"
              alt=""
              width="28"
              height="28"
              onerror="this.style.display='none'"
            />
          </div>
          <span class="footer-logo__name">TCHS <strong>Aero</strong></span>
        </a>

        <p class="footer-tagline">
          Temple City High School's competitive aeronautics and drone engineering club — pushing the boundaries of student innovation.
        </p>

        <address class="footer-address">
          <span>9501 Lemon Ave, Temple City, CA 91780</span>
          <a href="mailto:tchsaero@tcusd.net">tchsaero@tcusd.net</a>
        </address>

        <div class="footer-social">
          <a
            href="https://www.instagram.com/tchs.aero/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="TCHS Aero on Instagram"
            class="social-icon"
          >
            <!-- Instagram SVG -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Nav groups -->
      {footerGroups.map(group => (
        <div class="footer-nav-group">
          <p class="footer-nav-group__title">{group.title}</p>
          <ul class="footer-nav-group__list">
            {group.links.map(link => (
              <li>
                <a href={link.href} class="footer-nav-group__link">{link.text}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <!-- Copyright bar -->
  <div class="footer-bar">
    <div class="container footer-bar__inner">
      <p class="footer-bar__copy">&copy; {year} TCHS Aero. All rights reserved.</p>
      <div class="footer-bar__links">
        <a href="/privacy-policy">Privacy</a>
        <a href="/terms-of-service">Terms</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-charcoal);
    color: var(--color-white);
  }

  /* Main section */
  .footer-main {
    padding-block: var(--space-16) var(--space-20);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr;
      gap: var(--space-12);
    }
    .footer-brand { grid-column: 1; }
  }

  /* Brand */
  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: var(--space-6);
  }

  .footer-logo__icon {
    width: 2.5rem;
    height: 2.5rem;
    background: var(--color-red);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .footer-logo__icon img {
    height: 1.75rem;
    width: auto;
  }

  .footer-logo__name {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 300;
    color: var(--color-white);
  }

  .footer-tagline {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.72); /* was 0.55 — bumped for WCAG AA */
    line-height: 1.7;
    max-width: 22rem;
    margin-bottom: var(--space-6);
  }

  .footer-address {
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.65); /* was 0.45 — bumped for WCAG AA */
    margin-bottom: var(--space-8);
  }

  .footer-address a {
    transition: color var(--duration-fast) ease;
  }
  .footer-address a:hover {
    color: var(--color-white);
  }

  /* Social icon */
  .footer-social {
    display: flex;
    gap: 1rem;
  }

  .social-icon {
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.5);
    transition:
      background    var(--duration-base) ease,
      border-color  var(--duration-base) ease,
      color         var(--duration-base) ease;
  }

  .social-icon:hover {
    background:   var(--color-red);
    border-color: var(--color-red);
    color:        var(--color-white);
  }

  /* Nav groups */
  .footer-nav-group__title {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55); /* was 0.35 */
    margin-bottom: var(--space-5);
  }

  .footer-nav-group__link {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.72); /* was 0.55 */
    transition: color var(--duration-fast) ease;
  }
  .footer-nav-group__link:hover {
    color: var(--color-white);
  }

  /* Copyright bar */
  .footer-bar {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer-bar__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    padding-block: var(--space-5);
  }

  @media (min-width: 640px) {
    .footer-bar__inner {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer-bar__copy {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.50); /* was 0.25 */
  }

  .footer-bar__links {
    display: flex;
    gap: var(--space-6);
  }

  .footer-bar__links a {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.6); /* raised from 0.25 → ~7.2:1 contrast on #1c1c1c ✓ WCAG AA */
    transition: color var(--duration-fast) ease;
  }
  .footer-bar__links a:hover {
    color: rgba(255, 255, 255, 0.9);
  }
</style>
