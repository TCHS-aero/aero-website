---
/**
 * PageHero.astro — Reusable full-width page hero banner.
 *
 * Usage:
 *   import PageHero from '../components/Global/PageHero.astro';
 *   import heroImg  from '../assets/uploads/about/2about-us.png';
 *
 *   <PageHero src={heroImg} label="TCHS Aero" heading="About Us" />
 *
 * Props:
 *   src      — imported ImageMetadata (Astro auto-generates WebP on build)
 *   label    — small all-caps label above the h1 (e.g. "Updates")
 *   heading  — the h1 text
 *   alt      — image alt text (defaults to '' for decorative hero images)
 *   variant  — 'default' (dark charcoal overlay) | 'red' (brand-red overlay)
 *
 * The component injects nothing into <head>; the parent BaseLayout handles
 * the LCP preload hint automatically when you pass `image={heroImg}`.
 */
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src:       ImageMetadata;
  label:     string;
  heading:   string;
  alt?:      string;
  variant?:  'default' | 'red';
}

const { src, label, heading, alt = '', variant = 'default' } = Astro.props;
---

<section class:list={['page-hero', variant === 'red' && 'page-hero--red']}>
  <Picture
    src={src}
    widths={[800, 1200, 1536]}
    formats={['webp', 'png']}
    sizes="100vw"
    alt={alt}
    class="page-hero__img"
    loading="eager"
    fetchpriority="high"
    decoding="async"
  />
  <div class="page-hero__overlay"></div>
  <div class="page-hero__content">
    <div class="container">
      <span class="section-label section-label--light">{label}</span>
      <h1>{heading}</h1>
    </div>
  </div>
  <div class="page-hero__bar"></div>
</section>

<style>
  /*
   * Base .page-hero styles live in global.css.
   * This component only adds:
   *   1. The <picture> display fix (Astro wraps <Picture> in a <picture> element)
   *   2. The red overlay variant for the Sponsor page
   */

  /* Make Astro's <picture> wrapper transparent to layout */
  .page-hero :global(picture) {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* Red overlay variant (Sponsor page) */
  .page-hero--red .page-hero__overlay {
    background: rgba(101, 2, 7, 0.8);
  }

  .page-hero--red .page-hero__bar {
    background: rgba(255, 255, 255, 0.25);
  }
</style>
