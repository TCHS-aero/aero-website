---
/**
 * news.astro — News listing page
 *
 * Articles come from src/content/news/*.md — edit those files to update content,
 * or add a new .md file to publish a new article.
 *
 * To write a new article:
 *   1. Duplicate any file in src/content/news/
 *   2. Drop the article image in the same folder: e.g. ./my-photo.png
 *   3. Update frontmatter (title, date, label, image, excerpt)
 *   4. Set hasFullArticle: false to hide the "Read More" button
 *   5. Save — the article appears automatically
 */
import { getCollection, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero   from '../components/Global/PageHero.astro';
import { formatDate } from '../utils/dateUtils';
import heroImg from '../assets/uploads/news/3news.png';

type Article = CollectionEntry<'news'>;

const articles: Article[] = (
  (await getCollection('news', (entry: Article) => !entry.data.draft)) as Article[]
).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const [featured, ...rest] = articles;
---

<BaseLayout
  title="News — TCHS Aero"
  description="Stay up to date with the latest news, competition results, and announcements from TCHS Aero."
  image={heroImg}
>

  <PageHero src={heroImg} label="Updates" heading="News & Stories" />

  <div class="news-page">
    <div class="container">

      <!-- Featured article -->
      {featured && (
        <article class="featured reveal">
          <div class="featured__img-wrap">
            {featured.data.image ? (
              <Image
                src={featured.data.image}
                alt={featured.data.title}
                class="featured__img"
                width={800}
                format="webp"
                loading="eager"
                fetchpriority="high"
                decoding="async"
              />
            ) : (
              <div class="featured__img-placeholder" aria-hidden="true"></div>
            )}
          </div>
          <div class="featured__body bg-cream">
            <div class="featured__meta">
              <span class="featured__tag">{featured.data.label}</span>
              <span class="featured__sep" aria-hidden="true"></span>
              <time datetime={featured.data.date.toISOString()} class="featured__date">
                {formatDate(featured.data.date)}
              </time>
            </div>
            <h2 class="featured__title">{featured.data.title}</h2>
            <span class="accent-line"></span>
            <p class="featured__excerpt">{featured.data.excerpt}</p>
            {featured.data.hasFullArticle !== false && (
              <a href={`/news/${featured.slug}`} class="btn btn--primary">Read Full Story</a>
            )}
          </div>
        </article>
      )}

      <!-- Article grid -->
      {rest.length > 0 && (
        <div class="article-grid">
          {rest.map((article, i) => (
            <article class={`article-card reveal reveal--delay-${(i % 3) + 1}`}>
              {article.data.image && (
                <div class="article-card__img-wrap">
                  <Image
                    src={article.data.image}
                    alt={article.data.title}
                    class="article-card__img"
                    width={800}
                    format="webp"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              )}
              <div class="article-card__body">
                <div class="article-card__meta">
                  <span class="article-card__tag">{article.data.label}</span>
                  <span class="article-card__sep" aria-hidden="true"></span>
                  <time datetime={article.data.date.toISOString()} class="article-card__date">
                    {formatDate(article.data.date)}
                  </time>
                </div>
                <h3 class="article-card__title">{article.data.title}</h3>
                <p class="article-card__excerpt">{article.data.excerpt}</p>
                {article.data.hasFullArticle !== false && (
                  <a href={`/news/${article.slug}`} class="article-card__link">
                    Read More <span aria-hidden="true">→</span>
                  </a>
                )}
              </div>
            </article>
          ))}
        </div>
      )}

      {articles.length === 0 && (
        <p class="empty-state">No articles published yet. Check back soon.</p>
      )}

    </div>
  </div>

</BaseLayout>

<style>
  .news-page { padding-block: var(--space-16) var(--space-24); }

  /* ── Featured ── */
  .featured {
    display: grid;
    grid-template-columns: 1fr;
    margin-bottom: var(--space-16);
  }

  @media (min-width: 1024px) {
    .featured { grid-template-columns: 1fr 1fr; }
  }

  .featured__img-wrap {
    overflow: hidden;
    min-height: 300px;
  }

  @media (min-width: 1024px) {
    .featured__img-wrap { min-height: unset; }
  }

  .featured__img,
  .featured__img-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }

  .featured__img-placeholder { background: var(--color-cream-dark); }

  .featured:hover .featured__img { transform: scale(1.04); }

  .featured__body {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 3rem 3.5rem;
  }

  @media (min-width: 768px) { .featured__body { padding: 4rem 4.5rem; } }

  .featured__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
  }

  .featured__tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-red);
  }

  .featured__sep {
    display: block;
    width: 1rem; height: 1px;
    background: var(--color-gray-light);
  }

  .featured__date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-gray);
  }

  .featured__title {
    font-size: var(--text-3xl);
    font-weight: 300;
    line-height: 1.2;
    margin-bottom: var(--space-2);
  }

  @media (min-width: 768px) { .featured__title { font-size: var(--text-4xl); } }

  .featured__excerpt {
    font-family: var(--font-sans);
    color: var(--color-gray);
    margin-bottom: var(--space-8);
    line-height: 1.75;
  }

  /* ── Article grid ── */
  .article-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 640px) { .article-grid { grid-template-columns: 1fr 1fr; } }

  .article-card {
    border: 1px solid var(--color-cream-dark);
    transition: transform var(--duration-slow) var(--ease-expo), box-shadow var(--duration-slow) ease;
  }

  .article-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.08);
  }

  .article-card__img-wrap {
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .article-card__img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }
  .article-card:hover .article-card__img { transform: scale(1.05); }

  .article-card__body { padding: var(--space-8); }

  .article-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .article-card__tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-red);
  }

  .article-card__sep {
    display: block;
    width: 1rem; height: 1px;
    background: var(--color-cream-dark);
  }

  .article-card__date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-gray);
  }

  .article-card__title {
    font-size: var(--text-2xl);
    font-weight: 400;
    line-height: 1.3;
    margin-bottom: var(--space-3);
    transition: color var(--duration-fast) ease;
  }
  .article-card:hover .article-card__title { color: var(--color-red); }

  .article-card__excerpt {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-gray);
    line-height: 1.75;
    margin-bottom: var(--space-6);
  }

  .article-card__link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-red);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    transition: gap var(--duration-base) ease;
  }
  .article-card:hover .article-card__link { gap: var(--space-4); }

  .empty-state {
    font-family: var(--font-sans);
    color: var(--color-gray);
    text-align: center;
    padding: var(--space-20) 0;
  }
</style>
