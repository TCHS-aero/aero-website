---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — TCHS Aero"
  description="Get in touch with TCHS Aero. We'd love to hear from students, families, sponsors, and community members."
  image="/uploads/contact/4contact.png"
>

  <link
    slot="head"
    rel="preload"
    as="image"
    href="/uploads/contact/4contact-1200w.webp"
    type="image/webp"
    imagesrcset="/uploads/contact/4contact-800w.webp 800w, /uploads/contact/4contact-1200w.webp 1200w"
    imagesizes="100vw"
    fetchpriority="high"
  />

  <section class="page-hero">
    <picture>
      <source
        srcset="/uploads/contact/4contact-800w.webp 800w, /uploads/contact/4contact-1200w.webp 1200w"
        sizes="100vw"
        type="image/webp"
      />
      <img src="/uploads/contact/4contact.png" alt="" class="page-hero__img" role="presentation" width="1536" height="1024" fetchpriority="high" decoding="async" />
    </picture>
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content">
      <div class="container">
        <span class="section-label section-label--light">Reach Out</span>
        <h1>Get in Touch</h1>
      </div>
    </div>
    <div class="page-hero__bar"></div>
  </section>

  <section class="contact-section">
    <div class="container contact-grid">

      <!-- Info column -->
      <div class="contact-info reveal">
        <span class="section-label">Contact</span>
        <h2>
          We'd love to<br/>
          hear from you.
        </h2>
        <span class="accent-line"></span>

        <div class="info-items">
          <div class="info-item">
            <span class="info-item__label">Email</span>
            <a href="mailto:tchsaero@tcusd.net" class="info-item__value">tchsaero@tcusd.net</a>
          </div>
          <div class="info-item">
            <span class="info-item__label">School</span>
            <address class="info-item__value info-item__value--address">
              Temple City High School<br/>
              9501 Lemon Ave<br/>
              Temple City, CA 91780
            </address>
          </div>
          <div class="info-item">
            <span class="info-item__label">Social</span>
            <a
              href="https://www.instagram.com/tchs.aero/"
              target="_blank"
              rel="noopener noreferrer"
              class="info-item__social"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
              @tchs.aero on Instagram
            </a>
          </div>
        </div>
      </div>

      <!-- Form column -->
      <div class="contact-form-wrap reveal reveal--delay-1">
        <div class="contact-form-box">
          <h3>Send a Message</h3>

          <!--
            Form note: the mailto: action works without a backend.
            For production, replace with Formspree, Netlify Forms, etc.
            See: https://formspree.io or https://docs.netlify.com/forms/setup/
          -->
          <form class="contact-form" action="mailto:tchsaero@tcusd.net" method="post" enctype="text/plain">
            <div class="form-row">
              <div class="form-field">
                <label for="name" class="form-label">Name</label>
                <input type="text" id="name" name="name" required placeholder="Your name" class="form-input" />
              </div>
              <div class="form-field">
                <label for="email" class="form-label">Email</label>
                <input type="email" id="email" name="email" required placeholder="your@email.com" class="form-input" />
              </div>
            </div>

            <div class="form-field">
              <label for="subject" class="form-label">Topic</label>
              <select id="subject" name="subject" class="form-input form-select">
                <option value="">Select a topic</option>
                <option value="general">General Inquiry</option>
                <option value="membership">Club Membership</option>
                <option value="sponsorship">Sponsorship</option>
                <option value="media">Media / Press</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="form-field">
              <label for="message" class="form-label">Message</label>
              <textarea id="message" name="message" rows="5" required placeholder="Tell us what's on your mind…" class="form-input form-textarea"></textarea>
            </div>

            <button type="submit" class="btn btn--primary">Send Message</button>
          </form>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .contact-section { padding-block: var(--space-20) var(--space-28); }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }

  @media (min-width: 1024px) {
    .contact-grid {
      grid-template-columns: 2fr 3fr;
      gap: var(--space-20);
    }
  }

  /* ── Info column ── */
  .contact-info h2 { margin-bottom: var(--space-2); }
  .contact-info h2 em { font-style: italic; color: var(--color-red); }

  .info-items {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .info-item__label {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-red);
    margin-bottom: var(--space-2);
  }

  .info-item__value {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-charcoal);
    transition: color var(--duration-fast) ease;
  }

  .info-item__value--address {
    font-style: normal;
    color: var(--color-gray);
    font-size: var(--text-sm);
    line-height: 1.75;
  }

  a.info-item__value:hover { color: var(--color-red); }

  .info-item__social {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-gray);
    transition: color var(--duration-fast) ease;
  }
  .info-item__social:hover { color: var(--color-red); }

  /* ── Form ── */
  .contact-form-box {
    background: var(--color-cream-light);
    padding: var(--space-8) var(--space-8) var(--space-10);
  }

  @media (min-width: 768px) {
    .contact-form-box { padding: var(--space-10) var(--space-12); }
  }

  .contact-form-box h3 {
    font-size: var(--text-2xl);
    font-weight: 400;
    margin-bottom: var(--space-8);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 480px) {
    .form-row { grid-template-columns: 1fr 1fr; }
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .form-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-red);
  }

  .form-input {
    background: var(--color-white);
    border: 1px solid var(--color-cream-dark);
    padding: 0.75rem 1rem;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-charcoal);
    width: 100%;
    transition: border-color var(--duration-fast) ease;
    appearance: none;
  }

  .form-input::placeholder { color: var(--color-gray-light); }
  .form-input:focus { outline: none; border-color: var(--color-red); }

  .form-textarea { resize: none; }

  .form-select { cursor: pointer; }
</style>
