---
/**
 * index.astro — Homepage
 * ────────────────────────
 * To edit content: update the data arrays below (stats, programs, articles, sponsors).
 * To change layout or design: edit the <style> block at the bottom.
 * To change colors/fonts: edit src/assets/styles/global.css → :root variables.
 */
import BaseLayout from '../layouts/BaseLayout.astro';

interface Stat { value: string; label: string; }

const stats: Stat[] = [
/*
  { value: '2', label: 'Years of Flight'   },
  { value: '27', label: 'Club Members'      },
  { value: '2',   label: 'Drones'  }
*/
];

const programs = [
  {
    icon:  '',
    title: 'Build & Engineer',
    desc:  'Our members design and assemble drones from the ground up.',
  },
  {
    icon:  '',
    title: 'Compete',
    desc:  'We represent Temple City at SUAS, testing our skills against the best student teams internationally.',
  },
  {
    icon:  '',
    title: 'Fly & Innovate',
    desc:  'We explore new flight technologies through rigorous optimization.',
  },
];

const articles = [
  {
    img:     '/uploads/news/news 1.webp',
    imgFallback: '/uploads/news/articles/news 1.png',
    label:   'Competition',
    date:    '2024',
    title:   'TCHS Aero Advances to Regional Finals',
    excerpt: 'The team put in an exceptional performance at the district qualifier, securing a spot at the regional championship.',
  },
  {
    img:     '/uploads/news/news 2.webp',
    imgFallback: '/uploads/news/news 2.png',
    label:   'Program Update',
    date:    '2024',
    title:   'New FPV Racing Division Launches',
    excerpt: 'We\'re excited to introduce our new FPV racing division for members interested in high-speed drone piloting.',
  },
  {
    img:     '/uploads/news/news 3.webp',
    imgFallback: '/uploads/news/news 3.png',
    label:   'Sponsors',
    date:    '2024',
    title:   'Welcoming Our New Partners',
    excerpt: 'TCHS Aero is proud to announce new partnerships helping fund equipment and travel for the upcoming season.',
  },
];

const sponsors = [
  { src: '/uploads/sponsor/tcsf-logo-transparent.webp', fallback: '/uploads/sponsor/tcsf-logo-transparent.png', alt: 'Temple City Schools Foundation' },
  { src: '/uploads/sponsor/frsky.webp',                 fallback: '/uploads/sponsor/frsky.png',                 alt: 'FrSky' },
  { src: '/uploads/sponsor/hitec.webp',                 fallback: '/uploads/sponsor/hitec.png',                 alt: 'Hitec' },
];
---

<BaseLayout>

  <!-- ═══ HERO ═══════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero__bg">
      <picture>
        <source srcset="/uploads/home/1home.webp" type="image/webp" />
        <img
          src="/uploads/home/1home.png"
          alt="TCHS Aero drone in flight"
          class="hero__photo"
          width="1536"
          height="1024"
          fetchpriority="high"
          decoding="sync"
        />
      </picture>
      <div class="hero__gradient"></div>
      <div class="hero__grid" aria-hidden="true"></div>
    </div>

    <div class="container hero__body">
      <div class="hero__content">
        <span class="section-label section-label--light reveal">Est. Temple City High School</span>
        <h1 class="hero__heading reveal reveal--delay-1">
          Where<br/>
          <em>Engineering</em><br/>
          Takes Flight
        </h1>
        <p class="hero__sub reveal reveal--delay-2">
          TCHS Aero is Temple City High School's competitive aeronautics and drone engineering
          club — where students design, build, and push the limits of flight.
        </p>
        <div class="hero__actions reveal reveal--delay-3">
          <a href="/about-us" class="btn btn--primary">Discover Our Story</a>
          <a href="/sponsor"   class="btn btn--ghost">Support the Club</a>
        </div>
      </div>
    </div>

    <div class="hero__bar" aria-hidden="true"></div>
  </section>

  <!-- ═══ STATS ══════════════════════════════════════════════════ -->
  <section class="stats">
    <div class="container stats__grid">
      {stats.map(stat => (
        <div class="stats__item reveal">
          <span class="stats__value">{stat.value}</span>
          <span class="stats__label">{stat.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ ABOUT PREVIEW ═══════════════════════════════════════════ -->
  <section class="about-preview bg-cream">
    <div class="container about-preview__grid">

      <div class="about-preview__img-wrap reveal">
        <picture>
          <source srcset="/uploads/home/our story photo.webp" type="image/webp" />
          <img
            src="/uploads/home/our story photo.jpeg"
            alt="TCHS Aero team members"
            class="about-preview__img"
            width="1200"
            height="900"
            loading="lazy"
            decoding="async"
          />
        </picture>
        <div class="about-preview__corner-h" aria-hidden="true"></div>
        <div class="about-preview__corner-v" aria-hidden="true"></div>
        <div class="about-preview__badge" aria-hidden="true">
          <span class="about-preview__badge-sub">Est.</span>
          <span class="about-preview__badge-name">TCHS</span>
        </div>
      </div>

      <div class="about-preview__text reveal reveal--delay-1">
        <span class="section-label">Our Story</span>
        <h2 class="about-preview__heading">
          Passion for Flight,<br/>
          <em>Driven by Students</em>
        </h2>
        <span class="accent-line"></span>
        <p class="about-preview__body">
          TCHS Aero was founded on a simple idea: that high school students are fully capable
          of engineering aircraft that fly. What started as a small group of aerospace enthusiasts
          has grown into a serious, competitive program.
        </p>
        <p class="about-preview__body">
          Our members learn to apply real engineering principles — aerodynamics, electronics,
          programming — to build and pilot heavy-lift autonomous aircraft in the SUAS competition.
        </p>
        <a href="/about-us" class="btn btn--outline">Learn More About Us</a>
      </div>
    </div>
  </section>

  <!-- ═══ PROGRAMS ════════════════════════════════════════════════ -->
  <section class="programs">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">Programs</span>
        <h2>What We Do</h2>
      </div>

      <div class="programs__grid">
        {programs.map((p, i) => (
          <div class={`programs__card reveal reveal--delay-${i + 1}`}>
            <span class="programs__icon" aria-hidden="true">{p.icon}</span>
            <h3 class="programs__title">{p.title}</h3>
            <span class="accent-line"></span>
            <p class="programs__desc">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ SPONSORS ════════════════════════════════════════════════ -->
  <section class="sponsors">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">Our Partners</span>
        <h2>Supported By</h2>
      </div>
      <div class="sponsors__logos">
        {sponsors.map(s => (
          <div class="reveal">
            <picture>
              <source srcset={s.src} type="image/webp" />
              <img src={s.fallback} alt={s.alt} class="sponsor-logo" loading="lazy" decoding="async" width="224" height="128" />
            </picture>
          </div>
        ))}
      </div>
      <div class="sponsors__cta reveal">
        <a href="/sponsor" class="btn btn--outline">Become a Sponsor</a>
      </div>
    </div>
  </section>

  <!-- ═══ CTA BANNER ══════════════════════════════════════════════ -->
  <section class="cta-banner">
    <div class="cta-banner__orbs" aria-hidden="true">
      <div class="cta-banner__orb cta-banner__orb--tr"></div>
      <div class="cta-banner__orb cta-banner__orb--bl"></div>
    </div>
    <div class="container cta-banner__content">
      <span class="section-label section-label--light reveal">Get Involved</span>
      <h2 class="cta-banner__heading reveal reveal--delay-1">
        Ready to Join<br/><em>the Crew?</em>
      </h2>
      <p class="cta-banner__sub reveal reveal--delay-2">
        Whether you're a student eager to join or a business looking to partner with the
        next generation of aerospace engineers — we'd love to hear from you.
      </p>
      <div class="cta-banner__actions reveal reveal--delay-3">
        <a href="/contact" class="btn btn--ghost">Contact Us</a>
        <a href="/sponsor"  class="btn btn--white">Sponsor the Team</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    height: 90vh;
    min-height: 36rem;
    max-height: 56rem;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
  }

  .hero__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero__gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(101, 2, 7, 0.88) 0%,
      rgba(101, 2, 7, 0.55) 55%,
      rgba(0, 0, 0, 0.1) 100%
    );
  }

  .hero__grid {
    position: absolute;
    inset: 0;
    opacity: 0.05;
    background-image:
      repeating-linear-gradient(0deg,   transparent, transparent 40px, rgba(255,255,255,0.5) 40px, rgba(255,255,255,0.5) 41px),
      repeating-linear-gradient(90deg,  transparent, transparent 40px, rgba(255,255,255,0.5) 40px, rgba(255,255,255,0.5) 41px);
  }

  .hero__body {
    position: relative;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-bottom: var(--space-16);
  }

  .hero__content { max-width: 40rem; }

  .hero__heading {
    font-size: var(--text-5xl);
    font-weight: 300;
    color: var(--color-white);
    line-height: 1.0;
    margin-bottom: var(--space-6);
  }

  .hero__heading em {
    font-style: italic;
    font-weight: 300;
  }

  @media (min-width: 768px)  { .hero__heading { font-size: var(--text-6xl); } }
  @media (min-width: 1024px) { .hero__heading { font-size: var(--text-7xl); } }

  .hero__sub {
    font-family: var(--font-sans);
    color: rgba(255, 255, 255, 0.88); /* was 0.75 — bumped for WCAG AA */
    font-size: var(--text-base);
    max-width: 28rem;
    margin-bottom: var(--space-10);
  }

  @media (min-width: 768px) { .hero__sub { font-size: var(--text-lg); } }

  .hero__actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  @media (min-width: 480px) { .hero__actions { flex-direction: row; } }

  .hero__bar {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 4px;
    background: var(--color-red);
  }

  /* ── Stats ── */
  .stats {
    background: var(--color-red);
    color: var(--color-white);
    padding-block: var(--space-10);
  }

  .stats__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .stats__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
    }
    .stats__item + .stats__item {
      border-left: 1px solid rgba(255, 255, 255, 0.2);
    }
  }

  .stats__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    padding-inline: var(--space-4);
  }

  .stats__value {
    font-family: var(--font-serif);
    font-size: var(--text-4xl);
    font-weight: 300;
  }

  .stats__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    text-align: center;
  }

  /* ── About Preview ── */
  .about-preview {
    padding-block: var(--space-20);
    overflow: hidden;
  }

  @media (min-width: 768px) { .about-preview { padding-block: var(--space-28); } }

  .about-preview__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }

  @media (min-width: 1024px) {
    .about-preview__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-20);
      align-items: center;
    }
  }

  .about-preview__img-wrap {
    position: relative;
  }

  .about-preview__img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  /* Red corner bracket decoration */
  .about-preview__corner-h {
    position: absolute;
    top: 0; left: 0;
    width: 3rem; height: 4px;
    background: var(--color-red);
  }

  .about-preview__corner-v {
    position: absolute;
    top: 0; left: 0;
    width: 4px; height: 3rem;
    background: var(--color-red);
  }

  .about-preview__badge {
    display: none;
    position: absolute;
    bottom: -1.25rem;
    right: -1.25rem;
    background: var(--color-red);
    color: var(--color-white);
    padding: var(--space-4) var(--space-6);
  }

  @media (min-width: 768px) { .about-preview__badge { display: block; } }

  .about-preview__badge-sub {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: var(--space-1);
  }

  .about-preview__badge-name {
    display: block;
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
  }

  .about-preview__heading {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-2);
  }

  @media (min-width: 768px) { .about-preview__heading { font-size: var(--text-5xl); } }

  .about-preview__heading em {
    font-style: italic;
    color: var(--color-red);
  }

  .about-preview__body {
    font-family: var(--font-sans);
    color: var(--color-gray);
    margin-bottom: var(--space-6);
  }

  /* ── Programs ── */
  .programs { padding-block: var(--space-20); }
  @media (min-width: 768px) { .programs { padding-block: var(--space-28); } }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-14);
  }

  .programs__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--color-cream-dark);
  }

  @media (min-width: 768px) {
    .programs__grid { grid-template-columns: repeat(3, 1fr); }
  }

  .programs__card {
    background: var(--color-white);
    padding: var(--space-10) var(--space-12);
  }

  .programs__icon {
    font-family: var(--font-serif);
    font-size: var(--text-4xl);
    color: var(--color-red);
    display: block;
    margin-bottom: var(--space-6);
  }

  .programs__title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 400;
    margin-bottom: var(--space-2);
  }

  .programs__desc {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-gray);
    line-height: 1.75;
  }

  /* ── News Preview ── */
  .news-preview {
    padding-block: var(--space-20);
  }

  @media (min-width: 768px) { .news-preview { padding-block: var(--space-28); } }

  .news-preview__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin-bottom: var(--space-20); /* ↑ increased from --space-14 */
  }

  @media (min-width: 768px) {
    .news-preview__header {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
    }
  }

  .news-preview__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .news-preview__grid { grid-template-columns: repeat(3, 1fr); gap: var(--space-8); }
  }

  /* News card */
  .news-card {
    background: var(--color-white);
    transition: transform var(--duration-slow) var(--ease-expo), box-shadow var(--duration-slow) ease;
  }

  .news-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.09);
  }

  .news-card__img-wrap {
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .news-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }
  .news-card:hover .news-card__img { transform: scale(1.05); }

  .news-card__body { padding: var(--space-6) var(--space-6) var(--space-8); }

  .news-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .news-card__tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-red);
  }

  .news-card__sep {
    display: block;
    width: 1rem;
    height: 1px;
    background: var(--color-cream-dark);
  }

  .news-card__date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-gray);
  }

  .news-card__title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 400;
    line-height: 1.25;
    margin-bottom: var(--space-3);
    transition: color var(--duration-fast) ease;
  }
  .news-card:hover .news-card__title { color: var(--color-red); }

  .news-card__excerpt {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-gray);
    line-height: 1.75;
    margin-bottom: var(--space-6);
  }

  .news-card__more {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-red);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    transition: gap var(--duration-base) ease;
  }
  .news-card:hover .news-card__more { gap: var(--space-4); }

  /* ── Sponsors ── */
  .sponsors {
    padding-block: var(--space-16) var(--space-20);
    border-top: 1px solid var(--color-cream-dark);
  }

  .sponsors__logos {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-10);
    margin-top: var(--space-16);
    margin-bottom: var(--space-12);
  }

  @media (min-width: 768px) { .sponsors__logos { gap: var(--space-16); } }

  .sponsor-logo {
    height: 8rem;
    width: auto;
    max-width: 14rem;
    object-fit: contain;
    filter: grayscale(0);
    opacity: 1;
    transition: filter var(--duration-slow) ease, opacity var(--duration-slow) ease;
  }

  .sponsor-logo:hover {
    filter: grayscale(0);
    opacity: 1;
  }

  .sponsors__cta { text-align: center; }

  /* ── CTA Banner ── */
  .cta-banner {
    position: relative;
    padding-block: var(--space-20);
    background: var(--color-red);
    overflow: hidden;
    text-align: center;
  }

  @media (min-width: 768px) { .cta-banner { padding-block: var(--space-28); } }

  .cta-banner__orbs {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.06;
  }

  .cta-banner__orb {
    position: absolute;
    border: 1px solid var(--color-white);
    border-radius: 50%;
  }

  .cta-banner__orb--tr {
    width: 16rem; height: 16rem;
    top: 0; right: 0;
    transform: translate(50%, -50%);
  }

  .cta-banner__orb--bl {
    width: 24rem; height: 24rem;
    bottom: 0; left: 0;
    transform: translate(-50%, 50%);
  }

  .cta-banner__content { position: relative; }

  .cta-banner__heading {
    font-size: var(--text-4xl);
    font-weight: 300;
    color: var(--color-white);
    margin-bottom: var(--space-6);
  }

  @media (min-width: 768px)  { .cta-banner__heading { font-size: var(--text-5xl); } }
  @media (min-width: 1024px) { .cta-banner__heading { font-size: var(--text-6xl); } }

  .cta-banner__heading em { font-style: italic; }

  .cta-banner__sub {
    font-family: var(--font-sans);
    color: rgba(255, 255, 255, 0.7);
    max-width: 28rem;
    margin-inline: auto;
    margin-bottom: var(--space-10);
  }

  .cta-banner__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  @media (min-width: 480px) {
    .cta-banner__actions { flex-direction: row; justify-content: center; }
  }
</style>