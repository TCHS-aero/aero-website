---
/**
 * index.astro — Homepage
 * ────────────────────────
 * To edit content: update the data arrays below (stats, programs, sponsors).
 * To change layout or design: edit the <style> block at the bottom.
 * To change colors/fonts: edit src/assets/styles/global.css → :root variables.
 *
 * IMAGES
 * ──────
 * Hero and about-section images are imported from src/assets/uploads/.
 * Astro automatically generates WebP variants at build time — no manual
 * conversion or naming of *-800w.webp files is needed.
 * To swap an image, replace the file in src/assets/uploads/ and update the
 * import below.
 */
import { Picture } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SponsorLogo from '../components/SponsorLogo.astro';
import { sponsors, orbiterSponsors } from '../content/sponsors';
import type { Sponsor } from '../content/sponsors';

// ── Image imports ────────────────────────────────────────────────────────────
import heroImg     from '../assets/uploads/home/1home.png';
import ourStoryImg from '../assets/uploads/home/our-story-photo.jpeg';

// ── Page data ────────────────────────────────────────────────────────────────
interface Stat { value: string; label: string; }

const stats: Stat[] = [
/*
  { value: '2',  label: 'Years of Flight' },
  { value: '27', label: 'Club Members'    },
  { value: '2',  label: 'Drones'          },
*/
];

const programs = [
  {
    icon:  '',
    title: 'Build & Engineer',
    desc:  'Our members design and assemble drones from the ground up.',
  },
  {
    icon:  '',
    title: 'Compete',
    desc:  'We represent Temple City at SUAS, testing our skills against the best student teams internationally.',
  },
  {
    icon:  '',
    title: 'Fly & Innovate',
    desc:  'We explore new flight technologies through rigorous optimization.',
  },
];
---

<BaseLayout image={heroImg}>



  <section class="hero">
    <div class="hero__bg">
      <Picture
        src={heroImg}
        widths={[800, 1200, 1536]}
        formats={['webp', 'png']}
        sizes="100vw"
        alt="TCHS Aero drone in flight"
        class="hero__photo"
        loading="eager"
        fetchpriority="high"
      />
      <div class="hero__gradient"></div>
      <div class="hero__grid" aria-hidden="true"></div>
    </div>

    <div class="container hero__body">
      <div class="hero__content">
        <span class="section-label section-label--light reveal">Est. Temple City High School</span>
        <h1 class="hero__heading reveal reveal--delay-1">
          Where <em>Engineering</em><br/>
          Takes Flight
        </h1>
        <p class="hero__sub reveal reveal--delay-2">
          TCHS Aero is Temple City High School's competitive aeronautics and drone engineering
          club — where students design, build, and fly aircraft that push the limits of what's
          possible at the high school level.
        </p>
        <div class="hero__actions reveal reveal--delay-3">
          <a href="/about-us" class="btn btn--primary">Discover Our Story</a>
          <a href="/sponsor"  class="btn btn--ghost">Support the Club</a>
        </div>

        {orbiterSponsors.length > 0 && (
          <div class="hero__orbiter reveal reveal--delay-4">
            <p class="hero__orbiter-label">Orbiter Tier Sponsors</p>
            <ul class="hero__orbiter-logos" role="list">
              {orbiterSponsors.map((s: Sponsor) => (
                <li>
                  <SponsorLogo {...s} />
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </div>

    <div class="hero__bar" aria-hidden="true"></div>
  </section>


  <section class="stats">
    <div class="container stats__grid">
      {stats.map(stat => (
        <div class="stats__item reveal">
          <span class="stats__value">{stat.value}</span>
          <span class="stats__label">{stat.label}</span>
        </div>
      ))}
    </div>
  </section>


  <section class="about-preview bg-cream">
    <div class="container about-preview__grid">

      <div class="about-preview__img-wrap reveal">
        <Picture
          src={ourStoryImg}
          widths={[480, 700, 960]}
          formats={['webp', 'jpeg']}
          sizes="(min-width: 1024px) 50vw, 100vw"
          alt="TCHS Aero team members"
          class="about-preview__img"
          loading="lazy"
          decoding="async"
        />
        <div class="about-preview__corner-h" aria-hidden="true"></div>
        <div class="about-preview__corner-v" aria-hidden="true"></div>
        <div class="about-preview__badge" aria-hidden="true">
          <span class="about-preview__badge-sub">Est.</span>
          <span class="about-preview__badge-name">TCHS</span>
        </div>
      </div>

      <div class="about-preview__text reveal reveal--delay-1">
        <span class="section-label">Our Story</span>
        <h2 class="about-preview__heading">
          Passion for Flight,<br/>
          <em>Driven by Students</em>
        </h2>
        <span class="accent-line"></span>
        <p class="about-preview__body">
          TCHS Aero was founded on a simple idea: that high school students are fully capable
          of engineering aircraft that fly. What started as a small group of aerospace enthusiasts
          has grown into a serious, competitive program.
        </p>
        <p class="about-preview__body">
          Our members learn to apply real engineering principles — aerodynamics, electronics,
          programming — to build and pilot heavy-lift autonomous aircraft in the SUAS competition.
        </p>
        <a href="/about-us" class="btn btn--outline">Learn More About Us</a>
      </div>
    </div>
  </section>


  <section class="programs">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">Programs</span>
        <h2>What We Do</h2>
      </div>

      <div class="programs__grid">
        {programs.map((p, i) => (
          <div class={`programs__card reveal reveal--delay-${i + 1}`}>
            <span class="programs__icon" aria-hidden="true">{p.icon}</span>
            <h3 class="programs__title">{p.title}</h3>
            <span class="accent-line"></span>
            <p class="programs__desc">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <section class="sponsors">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">Our Partners</span>
        <h2>Supported By</h2>
      </div>
      <div class="sponsors__logos">
        {sponsors.map(s => (
          <div class="reveal">
            <SponsorLogo {...s} />
          </div>
        ))}
      </div>
      <div class="sponsors__cta reveal">
        <a href="/sponsor" class="btn btn--outline">Become a Sponsor</a>
      </div>
    </div>
  </section>


  <section class="cta-banner">
    <div class="cta-banner__orbs" aria-hidden="true">
      <div class="cta-banner__orb cta-banner__orb--tr"></div>
      <div class="cta-banner__orb cta-banner__orb--bl"></div>
    </div>
    <div class="container cta-banner__content">
      <span class="section-label section-label--light reveal">Get Involved</span>
      <h2 class="cta-banner__heading reveal reveal--delay-1">
        Ready to Join<br/><em>the Crew?</em>
      </h2>
      <p class="cta-banner__sub reveal reveal--delay-2">
        Whether you're a student eager to join or a business looking to partner with the
        next generation of aerospace engineers — we'd love to hear from you.
      </p>
      <div class="cta-banner__actions reveal reveal--delay-3">
        <a href="/contact" class="btn btn--ghost">Contact Us</a>
        <a href="/sponsor"  class="btn btn--white">Sponsor the Team</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Picture wrapper fix: Astro's <Picture> wraps <img> in a <picture> element.
        Setting display:block + full dimensions ensures it behaves like a plain <img>
        inside positioned containers. ── */
  .hero__bg :global(picture),
  .about-preview__img-wrap :global(picture) {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* ── Hero ── */
  .hero {
    position: relative;
    min-height: 44rem;
    height: auto;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
  }

  .hero__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero__gradient {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to right,
        rgba(101, 2, 7, 0.90) 0%,
        rgba(101, 2, 7, 0.60) 50%,
        rgba(0, 0, 0, 0.15) 100%
      ),
      linear-gradient(
        to top,
        rgba(0, 0, 0, 0.35) 0%,
        transparent 30%
      );
  }

  .hero__grid {
    position: absolute;
    inset: 0;
    opacity: 0.05;
    background-image:
      repeating-linear-gradient(0deg,   transparent, transparent 40px, rgba(255,255,255,0.5) 40px, rgba(255,255,255,0.5) 41px),
      repeating-linear-gradient(90deg,  transparent, transparent 40px, rgba(255,255,255,0.5) 40px, rgba(255,255,255,0.5) 41px);
  }

  .hero__body {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-block: var(--space-20);
  }

  .hero__content { max-width: 52rem; }

  .hero__heading {
    font-size: var(--text-5xl);
    font-weight: 300;
    color: var(--color-white);
    line-height: 1.0;
    margin-bottom: var(--space-4);
  }

  .hero__heading em {
    font-style: italic;
    font-weight: 300;
  }

  @media (min-width: 768px)  { .hero__heading { font-size: var(--text-5xl); } }
  @media (min-width: 1024px) { .hero__heading { font-size: var(--text-6xl); } }

  .hero__sub {
    font-family: var(--font-sans);
    color: rgba(255, 255, 255, 0.88);
    font-size: var(--text-base);
    max-width: 38rem;
    margin-bottom: var(--space-6);
    line-height: 1.75;
  }

  @media (min-width: 768px) { .hero__sub { font-size: var(--text-lg); } }

  .hero__actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  @media (min-width: 480px) { .hero__actions { flex-direction: row; } }

  .hero__orbiter {
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    max-width: 32rem;
  }

  .hero__orbiter-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, .9);
    margin-bottom: var(--space-6);
    line-height: 1;
  }

  .hero__orbiter-logos {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-8);
    list-style: none;
  }

  .hero__orbiter :global(.sponsor-logo) {
    height: 2.8rem;
    width: 6rem;
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: 0.65;
    transition: opacity var(--duration-slow) ease;
  }

  .hero__orbiter :global(.sponsor-logo):hover {
    opacity: 1;
  }

  .hero__bar {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 4px;
    background: var(--color-red);
  }

  /* ── Stats ── */
  .stats {
    background: var(--color-red);
    color: var(--color-white);
    padding-block: var(--space-10);
  }

  .stats__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .stats__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
    }
    .stats__item + .stats__item {
      border-left: 1px solid rgba(255, 255, 255, 0.2);
    }
  }

  .stats__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    padding-inline: var(--space-4);
  }

  .stats__value {
    font-family: var(--font-serif);
    font-size: var(--text-4xl);
    font-weight: 300;
  }

  .stats__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    text-align: center;
  }

  /* ── About Preview ── */
  .about-preview {
    padding-block: var(--space-20);
    overflow: hidden;
  }

  @media (min-width: 768px) { .about-preview { padding-block: var(--space-28); } }

  .about-preview__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }

  @media (min-width: 1024px) {
    .about-preview__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-20);
      align-items: center;
    }
  }

  .about-preview__img-wrap {
    position: relative;
  }

  .about-preview__img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  /* Red corner bracket decoration */
  .about-preview__corner-h {
    position: absolute;
    top: 0; left: 0;
    width: 3rem; height: 4px;
    background: var(--color-red);
  }

  .about-preview__corner-v {
    position: absolute;
    top: 0; left: 0;
    width: 4px; height: 3rem;
    background: var(--color-red);
  }

  .about-preview__badge {
    display: none;
    position: absolute;
    bottom: -1.25rem;
    right: -1.25rem;
    background: var(--color-red);
    color: var(--color-white);
    padding: var(--space-4) var(--space-6);
  }

  @media (min-width: 768px) { .about-preview__badge { display: block; } }

  .about-preview__badge-sub {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: var(--space-1);
  }

  .about-preview__badge-name {
    display: block;
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
  }

  .about-preview__heading {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-2);
  }

  @media (min-width: 768px) { .about-preview__heading { font-size: var(--text-5xl); } }

  .about-preview__heading em {
    font-style: italic;
    color: var(--color-red);
  }

  .about-preview__body {
    font-family: var(--font-sans);
    color: var(--color-gray);
    margin-bottom: var(--space-6);
  }

  /* ── Programs ── */
  .programs { padding-block: var(--space-20); }
  @media (min-width: 768px) { .programs { padding-block: var(--space-28); } }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-14);
  }

  .programs__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--color-cream-dark);
  }

  @media (min-width: 768px) {
    .programs__grid { grid-template-columns: repeat(3, 1fr); }
  }

  .programs__card {
    background: var(--color-white);
    padding: var(--space-10) var(--space-12);
  }

  .programs__icon {
    font-family: var(--font-serif);
    font-size: var(--text-4xl);
    color: var(--color-red);
    display: block;
    margin-bottom: var(--space-6);
  }

  .programs__title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 400;
    margin-bottom: var(--space-2);
  }

  .programs__desc {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-gray);
    line-height: 1.75;
  }

  /* ── Sponsors ── */
  .sponsors {
    padding-block: var(--space-16) var(--space-20);
    border-top: 1px solid var(--color-cream-dark);
  }

  .sponsors__logos {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-10);
    margin-top: var(--space-16);
    margin-bottom: var(--space-12);
  }

  @media (min-width: 768px) { .sponsors__logos { gap: var(--space-16); } }

  .sponsors__cta { text-align: center; }

  /* ── CTA Banner ── */
  .cta-banner {
    position: relative;
    padding-block: var(--space-20);
    background: var(--color-red);
    overflow: hidden;
    text-align: center;
  }

  @media (min-width: 768px) { .cta-banner { padding-block: var(--space-28); } }

  .cta-banner__orbs {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.06;
  }

  .cta-banner__orb {
    position: absolute;
    border: 1px solid var(--color-white);
    border-radius: 50%;
  }

  .cta-banner__orb--tr {
    width: 16rem; height: 16rem;
    top: 0; right: 0;
    transform: translate(50%, -50%);
  }

  .cta-banner__orb--bl {
    width: 24rem; height: 24rem;
    bottom: 0; left: 0;
    transform: translate(-50%, 50%);
  }

  .cta-banner__content { position: relative; }

  .cta-banner__heading {
    font-size: var(--text-4xl);
    font-weight: 300;
    color: var(--color-white);
    margin-bottom: var(--space-6);
  }

  @media (min-width: 768px)  { .cta-banner__heading { font-size: var(--text-5xl); } }
  @media (min-width: 1024px) { .cta-banner__heading { font-size: var(--text-6xl); } }

  .cta-banner__heading em { font-style: italic; }

  .cta-banner__sub {
    font-family: var(--font-sans);
    color: rgba(255, 255, 255, 0.7);
    max-width: 28rem;
    margin-inline: auto;
    margin-bottom: var(--space-10);
  }

  .cta-banner__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  @media (min-width: 480px) {
    .cta-banner__actions { flex-direction: row; justify-content: center; }
  }
</style>
