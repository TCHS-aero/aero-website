---
/**
 * BaseLayout.astro
 */
import Header from '../components/Global/Header.astro';
import Footer from '../components/Global/Footer.astro';
import '../assets/styles/global.css';

interface Props {
  title?:       string;
  description?: string;
  image?:       string;
}

const {
  title       = 'TCHS Aero — Temple City High School Aeronautics',
  description = 'TCHS Aero is Temple City High School\'s competitive aeronautics and drone engineering club. We build, fly, and compete.',
  image       = '/uploads/home/1home-1200w.webp',
} = Astro.props;

const siteUrl    = Astro.site ?? 'https://tchsaero.org';
const canonical  = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage    = new URL(image, siteUrl).toString();

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "TCHS Aero",
  "url": siteUrl.toString(),
  "logo": new URL('/uploads/aero-logo.svg', siteUrl).toString(),
  "description": "Temple City High School's competitive aeronautics and drone engineering club.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "9501 Lemon Ave",
    "addressLocality": "Temple City",
    "addressRegion": "CA",
    "postalCode": "91780",
    "addressCountry": "US"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "tchsaero@tcusd.net",
    "contactType": "general"
  },
  "sameAs": ["https://www.instagram.com/tchs.aero/"]
});
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#650207" />
  <meta name="robots" content="index, follow" />

  <link rel="icon" type="image/svg+xml" href="/uploads/aero-logo.svg" />
  <link rel="icon" type="image/png" href="/uploads/aero-logo.PNG" />
  <link rel="apple-touch-icon" href="/uploads/aero-logo.PNG" />
  <link rel="manifest" href="/site.webmanifest" />
  <link rel="canonical" href={canonical} />

  <title>{title}</title>
  <meta name="description" content={description} />

  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonical} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:site_name"   content="TCHS Aero" />

  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
  <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="preload"
    as="style"
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap&font-display=swap"
  />
  <link
    rel="stylesheet"
    media="print"
    onload="this.media='all'"
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap&font-display=swap"
  />
  <noscript>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap&font-display=swap"
    />
  </noscript>

  <script type="application/ld+json" set:html={jsonLd} />

  <slot name="head" />
</head>

<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />

  <script>
    const observer = new IntersectionObserver(
      (entries) => entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('in-view');
          observer.unobserve(e.target);
        }
      }),
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>
</body>
</html>
