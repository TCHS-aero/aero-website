---
/**
 * BaseLayout.astro
 *
 * The `image` prop accepts either:
 *   - An imported ImageMetadata object (from astro:assets) — optimised automatically
 *   - A plain string path (e.g. '/uploads/aero-logo.svg') — used as-is
 *
 * When `image` is ImageMetadata, BaseLayout also injects a <link rel="preload">
 * hint for the LCP hero image so individual pages don't need to do it manually.
 */
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Header from '../components/Global/Header.astro';
import Footer from '../components/Global/Footer.astro';
import '../assets/styles/global.css';
import { SITE, CONTACT } from '../config/site';

// Default OG image — imported so Astro processes it
import defaultOgSrc from '../assets/uploads/home/1home.png';

interface Props {
  title?:       string;
  description?: string;
  /** Pass an imported image (ImageMetadata) or a plain URL string. */
  image?:       ImageMetadata | string;
}

const {
  title       = SITE.defaultTitle,
  description = SITE.defaultDescription,
  image,
} = Astro.props;

// Resolve OG image URL (jpeg for best social-card compatibility)
const ogImageSrc: string = await (async () => {
  if (!image) {
    const processed = await getImage({ src: defaultOgSrc, format: 'jpeg', width: 1200, quality: 80 });
    return processed.src;
  }
  if (typeof image === 'string') return image;
  const processed = await getImage({ src: image, format: 'jpeg', width: 1200, quality: 80 });
  return processed.src;
})();

// Widths must match PageHero.astro / index.astro <Picture widths={[800,1200,1536]}>
const HERO_WIDTHS = [800, 1200, 1536] as const;

interface HeroPreload { srcset: string; sizes: string; }

const heroPreload: HeroPreload | null = image && typeof image !== 'string'
  ? await (async () => {
      const variants = await Promise.all(
        HERO_WIDTHS.map(w => getImage({ src: image as ImageMetadata, format: 'webp', width: w, quality: 72 }))
      );
      return {
        srcset: variants.map((v, i) => `${v.src} ${HERO_WIDTHS[i]}w`).join(', '),
        sizes:  '100vw',
      };
    })()
  : null;

const siteUrl   = Astro.site ?? SITE.url;
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage   = new URL(ogImageSrc, siteUrl).toString();

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": SITE.name,
  "url": siteUrl.toString(),
  "logo": new URL(SITE.logoPath, siteUrl).toString(),
  "description": SITE.schemaDescription,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": CONTACT.address.street,
    "addressLocality": CONTACT.address.city,
    "addressRegion": CONTACT.address.state,
    "postalCode": CONTACT.address.zip,
    "addressCountry": CONTACT.address.country,
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "email": CONTACT.email,
    "contactType": "general",
  },
  "sameAs": [CONTACT.instagramUrl],
});
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#650207" />
  <meta name="robots" content="index, follow" />

  <link rel="icon" type="image/svg+xml" href="/uploads/aero-logo.svg" />
  <link rel="icon" type="image/png" href="/uploads/aero-logo.PNG" />
  <link rel="apple-touch-icon" href="/uploads/aero-logo.PNG" />
  <link rel="manifest" href="/site.webmanifest" />
  <link rel="canonical" href={canonical} />

  <title>{title}</title>
  <meta name="description" content={description} />

  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonical} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:site_name"   content={SITE.name} />

  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
  <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="preload"
    as="style"
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap&font-display=swap"
  />
  <link
    rel="stylesheet"
    media="print"
    onload="this.media='all'"
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap&font-display=swap"
  />
  <noscript>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap&font-display=swap"
    />
  </noscript>

  <script type="application/ld+json" set:html={jsonLd} />


  {heroPreload && (
    <link
      rel="preload"
      as="image"
      imagesrcset={heroPreload.srcset}
      imagesizes={heroPreload.sizes}
      type="image/webp"
      fetchpriority="high"
    />
  )}


  <slot name="head" />
</head>

<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />

  <script>
    const observer = new IntersectionObserver(
      (entries) => entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('in-view');
          observer.unobserve(e.target);
        }
      }),
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>
</body>
</html>
